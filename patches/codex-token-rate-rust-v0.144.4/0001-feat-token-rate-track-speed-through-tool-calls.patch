new file mode 100644
index 0000000000000000000000000000000000000000..1666c7281be32d91cbe999ea39b31f29eb5fc99e
--- /dev/null
+++ b/codex-rs/core/src/live_token_rate.rs
@@ -0,0 +1,306 @@
+use std::fmt::Display;
+use std::path::PathBuf;
+use std::sync::atomic::AtomicU64;
+use std::sync::atomic::Ordering;
+use std::time::Duration;
+use std::time::Instant;
+use std::time::SystemTime;
+use std::time::UNIX_EPOCH;
+
+use codex_protocol::protocol::TokenUsage;
+use codex_utils_output_truncation::approx_tokens_from_byte_count;
+use serde::Serialize;
+
+#[cfg(unix)]
+use std::os::unix::net::UnixDatagram;
+#[cfg(unix)]
+use std::sync::OnceLock;
+
+#[cfg(unix)]
+const SOCKET_ENV_VAR: &str = "CODEX_TOKEN_RATE_SOCKET";
+const MIN_EMIT_INTERVAL: Duration = Duration::from_millis(50);
+const MIN_EMIT_TOKENS: u64 = 8;
+const PROTOCOL_VERSION: u8 = 1;
+
+static NEXT_STREAM_SEQUENCE: AtomicU64 = AtomicU64::new(1);
+
+pub(crate) struct LiveTokenRateReporter {
+    enabled: Option<EnabledReporter>,
+}
+
+struct EnabledReporter {
+    socket_path: PathBuf,
+    pid: u32,
+    session_id: String,
+    turn_id: String,
+    stream_id: String,
+    model: String,
+    total_output_bytes: usize,
+    emitted_estimated_tokens: u64,
+    pending_tokens: u64,
+    pending_bytes: usize,
+    last_emit_at: Instant,
+    state: ReporterState,
+}
+
+#[derive(Clone, Copy, PartialEq, Eq, Serialize)]
+#[serde(rename_all = "snake_case")]
+pub(crate) enum PostResponsePhase {
+    Idle,
+    ToolExecution,
+}
+
+#[derive(Clone, Copy, PartialEq, Eq)]
+enum ReporterState {
+    Streaming,
+    ToolExecution,
+    Finished,
+}
+
+#[derive(Serialize)]
+struct DeltaEvent<'a> {
+    v: u8,
+    event: &'static str,
+    ts_unix_ms: u64,
+    pid: u32,
+    session_id: &'a str,
+    turn_id: &'a str,
+    stream_id: &'a str,
+    model: &'a str,
+    kind: &'static str,
+    estimated_tokens: u64,
+    utf8_bytes: u64,
+}
+
+#[derive(Serialize)]
+struct ResponseCompletedEvent<'a> {
+    v: u8,
+    event: &'static str,
+    ts_unix_ms: u64,
+    pid: u32,
+    session_id: &'a str,
+    turn_id: &'a str,
+    stream_id: &'a str,
+    model: &'a str,
+    estimated_output_tokens: u64,
+    usage: Option<&'a TokenUsage>,
+    next_phase: PostResponsePhase,
+}
+
+#[derive(Serialize)]
+struct ToolExecutionCompletedEvent<'a> {
+    v: u8,
+    event: &'static str,
+    ts_unix_ms: u64,
+    pid: u32,
+    session_id: &'a str,
+    turn_id: &'a str,
+    stream_id: &'a str,
+    model: &'a str,
+}
+
+impl LiveTokenRateReporter {
+    pub(crate) fn new(
+        socket_path_override: Option<PathBuf>,
+        session_id: impl Display,
+        turn_id: &str,
+        model: &str,
+    ) -> Self {
+        Self::from_socket_path(
+            socket_path_override.or_else(configured_socket_path),
+            session_id,
+            turn_id,
+            model,
+        )
+    }
+
+    fn from_socket_path(
+        socket_path: Option<PathBuf>,
+        session_id: impl Display,
+        turn_id: &str,
+        model: &str,
+    ) -> Self {
+        let Some(socket_path) = socket_path.filter(|path| path.is_absolute()) else {
+            return Self { enabled: None };
+        };
+        let pid = std::process::id();
+        let sequence = NEXT_STREAM_SEQUENCE.fetch_add(1, Ordering::Relaxed);
+        Self {
+            enabled: Some(EnabledReporter {
+                socket_path,
+                pid,
+                session_id: session_id.to_string(),
+                turn_id: turn_id.to_string(),
+                stream_id: format!("{pid}-{sequence}"),
+                model: model.to_string(),
+                total_output_bytes: 0,
+                emitted_estimated_tokens: 0,
+                pending_tokens: 0,
+                pending_bytes: 0,
+                last_emit_at: Instant::now(),
+                state: ReporterState::Streaming,
+            }),
+        }
+    }
+
+    pub(crate) fn observe_completion_delta(&mut self, delta: &str) {
+        let Some(reporter) = self.enabled.as_mut() else {
+            return;
+        };
+        if reporter.state != ReporterState::Streaming || delta.is_empty() {
+            return;
+        }
+
+        reporter.total_output_bytes = reporter.total_output_bytes.saturating_add(delta.len());
+        reporter.pending_bytes = reporter.pending_bytes.saturating_add(delta.len());
+        let estimated_tokens = approx_tokens_from_byte_count(reporter.total_output_bytes);
+        let increment = estimated_tokens.saturating_sub(reporter.emitted_estimated_tokens);
+        if increment > 0 {
+            reporter.emitted_estimated_tokens = estimated_tokens;
+            reporter.pending_tokens = reporter.pending_tokens.saturating_add(increment);
+        }
+
+        if reporter.pending_tokens >= MIN_EMIT_TOKENS
+            || reporter.last_emit_at.elapsed() >= MIN_EMIT_INTERVAL
+        {
+            reporter.flush_delta();
+        }
+    }
+
+    pub(crate) fn response_completed(
+        &mut self,
+        usage: Option<&TokenUsage>,
+        next_phase: PostResponsePhase,
+    ) {
+        let Some(reporter) = self.enabled.as_mut() else {
+            return;
+        };
+        if reporter.state != ReporterState::Streaming {
+            return;
+        }
+
+        reporter.flush_delta();
+        reporter.send(&ResponseCompletedEvent {
+            v: PROTOCOL_VERSION,
+            event: "response_completed",
+            ts_unix_ms: unix_timestamp_ms(),
+            pid: reporter.pid,
+            session_id: &reporter.session_id,
+            turn_id: &reporter.turn_id,
+            stream_id: &reporter.stream_id,
+            model: &reporter.model,
+            estimated_output_tokens: approx_tokens_from_byte_count(reporter.total_output_bytes),
+            usage,
+            next_phase,
+        });
+        reporter.state = match next_phase {
+            PostResponsePhase::Idle => ReporterState::Finished,
+            PostResponsePhase::ToolExecution => ReporterState::ToolExecution,
+        };
+    }
+
+    pub(crate) fn tool_execution_completed(&mut self) {
+        if let Some(reporter) = self.enabled.as_mut() {
+            reporter.complete_tool_execution();
+        }
+    }
+}
+
+impl Drop for LiveTokenRateReporter {
+    fn drop(&mut self) {
+        if let Some(reporter) = self.enabled.as_mut() {
+            match reporter.state {
+                ReporterState::Streaming => reporter.flush_delta(),
+                ReporterState::ToolExecution => reporter.complete_tool_execution(),
+                ReporterState::Finished => {}
+            }
+        }
+    }
+}
+
+impl EnabledReporter {
+    fn flush_delta(&mut self) {
+        if self.pending_tokens == 0 {
+            return;
+        }
+        self.send(&DeltaEvent {
+            v: PROTOCOL_VERSION,
+            event: "delta",
+            ts_unix_ms: unix_timestamp_ms(),
+            pid: self.pid,
+            session_id: &self.session_id,
+            turn_id: &self.turn_id,
+            stream_id: &self.stream_id,
+            model: &self.model,
+            kind: "completion_output",
+            estimated_tokens: self.pending_tokens,
+            utf8_bytes: u64::try_from(self.pending_bytes).unwrap_or(u64::MAX),
+        });
+        self.pending_tokens = 0;
+        self.pending_bytes = 0;
+        self.last_emit_at = Instant::now();
+    }
+
+    fn complete_tool_execution(&mut self) {
+        if self.state != ReporterState::ToolExecution {
+            return;
+        }
+        self.send(&ToolExecutionCompletedEvent {
+            v: PROTOCOL_VERSION,
+            event: "tool_execution_completed",
+            ts_unix_ms: unix_timestamp_ms(),
+            pid: self.pid,
+            session_id: &self.session_id,
+            turn_id: &self.turn_id,
+            stream_id: &self.stream_id,
+            model: &self.model,
+        });
+        self.state = ReporterState::Finished;
+    }
+
+    fn send(&self, event: &impl Serialize) {
+        #[cfg(unix)]
+        if let Ok(payload) = serde_json::to_vec(event)
+            && let Some(socket) = sender_socket()
+        {
+            let _ = socket.send_to(&payload, &self.socket_path);
+        }
+
+        #[cfg(not(unix))]
+        let _ = event;
+    }
+}
+
+fn unix_timestamp_ms() -> u64 {
+    let millis = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .unwrap_or_default()
+        .as_millis();
+    u64::try_from(millis).unwrap_or(u64::MAX)
+}
+
+#[cfg(unix)]
+fn configured_socket_path() -> Option<PathBuf> {
