+use std::io;
+use std::os::unix::net::UnixDatagram;
+use std::time::Duration;
+
+use anyhow::Context;
+use anyhow::Result;
+use codex_utils_output_truncation::approx_tokens_from_byte_count;
+use core_test_support::responses;
+use core_test_support::test_codex::test_codex;
+use pretty_assertions::assert_eq;
+use serde_json::Value;
+use serde_json::json;
+use tempfile::TempDir;
+
+#[tokio::test(flavor = "multi_thread", worker_threads = 2)]
+async fn streamed_function_arguments_emit_rate_and_tool_lifecycle() -> Result<()> {
+    let server = responses::start_mock_server().await;
+    let call_id = "rate-update-plan";
+    let arguments = json!({
+        "plan": [{
+            "step": "observe streamed tool argument rate",
+            "status": "in_progress"
+        }]
+    })
+    .to_string();
+    responses::mount_sse_sequence(
+        &server,
+        vec![
+            responses::sse(vec![
+                responses::ev_response_created("resp-tool"),
+                json!({
+                    "type": "response.output_item.added",
+                    "item": {
+                        "type": "function_call",
+                        "id": "fc-rate-update-plan",
+                        "call_id": call_id,
+                        "name": "update_plan",
+                        "arguments": "",
+                        "status": "in_progress"
+                    }
+                }),
+                json!({
+                    "type": "response.function_call_arguments.delta",
+                    "item_id": "fc-rate-update-plan",
+                    "delta": &arguments,
+                }),
+                responses::ev_function_call(call_id, "update_plan", &arguments),
+                responses::ev_completed("resp-tool"),
+            ]),
+            responses::sse(vec![
+                responses::ev_assistant_message("msg-final", "done"),
+                responses::ev_completed("resp-final"),
+            ]),
+        ],
+    )
+    .await;
+
+    let socket_dir = TempDir::new()?;
+    let socket_path = socket_dir.path().join("rate.sock");
+    let receiver = UnixDatagram::bind(&socket_path)?;
+    receiver.set_read_timeout(Some(Duration::from_millis(500)))?;
+    let mut builder = test_codex().with_config(move |config| {
+        codex_core::test_support::set_live_token_rate_socket(config, socket_path);
+    });
+    let test = builder.build_with_auto_env(&server).await?;
+    test.submit_turn("exercise token rate").await?;
+
+    let events = receive_events(&receiver)?;
+    let delta = events
+        .iter()
+        .find(|event| event["event"] == "delta")
+        .context("missing completion delta event")?;
+    let stream_id = delta["stream_id"]
+        .as_str()
+        .context("delta missing stream id")?;
+    let stream_events = events
+        .iter()
+        .filter(|event| event["stream_id"] == stream_id)
+        .map(|event| event["event"].as_str().unwrap_or_default())
+        .collect::<Vec<_>>();
+    assert_eq!(
+        stream_events,
+        vec!["delta", "response_completed", "tool_execution_completed"]
+    );
+    assert_eq!(delta["kind"], "completion_output");
+    assert_eq!(delta["utf8_bytes"], json!(arguments.len()));
+    assert_eq!(
+        delta["estimated_tokens"],
+        json!(approx_tokens_from_byte_count(arguments.len()))
+    );
+    let completed = events
+        .iter()
+        .find(|event| event["event"] == "response_completed" && event["stream_id"] == stream_id)
+        .context("missing response completion event")?;
+    assert_eq!(completed["next_phase"], "tool_execution");
+    Ok(())
+}
+
+fn receive_events(receiver: &UnixDatagram) -> Result<Vec<Value>> {
+    let mut events = Vec::new();
+    let mut buffer = [0_u8; 16 * 1024];
+    loop {
+        match receiver.recv(&mut buffer) {
+            Ok(size) => events.push(serde_json::from_slice(&buffer[..size])?),
+            Err(err)
+                if matches!(
+                    err.kind(),
+                    io::ErrorKind::WouldBlock | io::ErrorKind::TimedOut
+                ) =>
+            {
+                return Ok(events);
+            }
+            Err(err) => return Err(err.into()),
+        }
+    }
+}
