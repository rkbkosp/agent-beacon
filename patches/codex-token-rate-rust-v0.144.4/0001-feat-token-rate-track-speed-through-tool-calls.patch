+fn delta(pid: u32, session_id: &str, stream_id: &str, estimated_tokens: u64) -> DeltaMessage {
+    DeltaMessage {
+        _pid: pid,
+        session_id: session_id.to_string(),
+        stream_id: stream_id.to_string(),
+        estimated_tokens,
+    }
+}
+
+fn response_completed(
+    session_id: &str,
+    stream_id: &str,
+    next_phase: PostResponsePhase,
+) -> ResponseCompletedMessage {
+    ResponseCompletedMessage {
+        _pid: 10,
+        session_id: session_id.to_string(),
+        stream_id: stream_id.to_string(),
+        next_phase,
+    }
+}
+
+fn tool_execution_completed(session_id: &str, stream_id: &str) -> ToolExecutionCompletedMessage {
+    ToolExecutionCompletedMessage {
+        _pid: 10,
