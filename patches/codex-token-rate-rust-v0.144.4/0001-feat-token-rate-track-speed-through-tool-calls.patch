+            tokens_per_second: 6.0,
+            raw_tokens_per_second: 6.0,
+            active_sessions: 2,
+            active_streams: 3,
+            tool_active_streams: 0,
+        }
+    );
+}
+
+#[test]
+fn sliding_window_expires_and_idle_rate_returns_to_zero() {
+    let start = Instant::now();
+    let mut aggregator = Aggregator::new(Duration::from_secs(2));
+    aggregator.record(
