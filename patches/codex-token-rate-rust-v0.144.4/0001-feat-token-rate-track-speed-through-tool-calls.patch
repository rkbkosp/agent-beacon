+#[cfg(unix)]
+fn completed_event(chunks: &[&str]) -> Result<Value> {
+    let (_temp_dir, path, receiver) = bound_receiver()?;
+    let mut reporter = reporter_for_path(path);
+    for chunk in chunks {
+        reporter.observe_completion_delta(chunk);
+    }
+    reporter.response_completed(/*usage*/ None, PostResponsePhase::Idle);
+
+    loop {
+        let event = recv_json(&receiver)?;
+        if event["event"] == "response_completed" {
+            return Ok(event);
+        }
+    }
+}
+
+#[cfg(unix)]
+fn bound_receiver() -> Result<(TempDir, PathBuf, UnixDatagram)> {
+    let temp_dir = TempDir::new()?;
+    let path = temp_dir.path().join("token-rate.sock");
+    let receiver = UnixDatagram::bind(&path)?;
+    receiver.set_read_timeout(Some(Duration::from_millis(200)))?;
+    Ok((temp_dir, path, receiver))
+}
+
+#[cfg(unix)]
+fn reporter_for_path(path: PathBuf) -> LiveTokenRateReporter {
+    LiveTokenRateReporter::from_socket_path(Some(path), "session", "turn", "model")
+}
+
+#[cfg(unix)]
+fn recv_json(receiver: &UnixDatagram) -> Result<Value> {
+    let mut buffer = [0_u8; 4096];
+    let size = receiver.recv(&mut buffer)?;
+    Ok(serde_json::from_slice(&buffer[..size])?)
+}
+
+#[cfg(unix)]
+fn assert_no_datagram(receiver: &UnixDatagram) -> Result<()> {
+    let mut buffer = [0_u8; 64];
+    match receiver.recv(&mut buffer) {
+        Err(err) if matches!(err.kind(), ErrorKind::WouldBlock | ErrorKind::TimedOut) => Ok(()),
+        Err(err) => Err(err.into()),
+        Ok(size) => Err(anyhow!("unexpected datagram with {size} bytes")),
+    }
+}
