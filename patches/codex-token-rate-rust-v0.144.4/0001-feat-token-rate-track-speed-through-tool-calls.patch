+}
+
+#[test]
+fn ema_uses_previous_smoothed_value() {
+    let start = Instant::now();
+    let mut aggregator = Aggregator::new(Duration::from_secs(2));
+    aggregator.record(
+        start,
+        delta(
+            /*pid*/ 10, "session", "stream", /*estimated_tokens*/ 10,
+        ),
+    );
+
+    let first = aggregator.snapshot(start, /*ema_alpha*/ 0.35);
+    let second = aggregator.snapshot(start, /*ema_alpha*/ 0.35);
+    assert_eq!(first.tokens_per_second, 1.75);
+    assert_eq!(second.tokens_per_second, 2.8875);
+    assert_eq!(second.raw_tokens_per_second, 5.0);
+}
