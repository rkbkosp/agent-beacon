+#![cfg(unix)]
+
+use std::fs;
+use std::io;
+use std::os::unix::fs::PermissionsExt;
+use std::os::unix::net::UnixDatagram;
+use std::process::Child;
+use std::process::Command;
+use std::process::Stdio;
+use std::thread;
+use std::time::Duration;
+use std::time::Instant;
+
+use anyhow::Result;
+use anyhow::anyhow;
+use pretty_assertions::assert_eq;
+use serde::Deserialize;
+use serde_json::json;
+use tempfile::TempDir;
+
+#[derive(Debug, Deserialize)]
+struct StateFile {
+    tokens_per_second: f64,
+    raw_tokens_per_second: f64,
+    active_sessions: usize,
+    active_streams: usize,
+    tool_active_streams: usize,
+}
+
+struct ChildGuard {
+    child: Child,
+    finished: bool,
+}
+
+impl ChildGuard {
+    fn new(child: Child) -> Self {
+        Self {
+            child,
+            finished: false,
+        }
+    }
+
+    fn terminate(&mut self) -> Result<()> {
+        // SAFETY: kill is called with the child PID and a standard signal number.
+        if unsafe { libc::kill(self.child.id() as i32, libc::SIGTERM) } != 0 {
+            return Err(io::Error::last_os_error().into());
+        }
+        let deadline = Instant::now() + Duration::from_secs(3);
+        loop {
+            if let Some(status) = self.child.try_wait()? {
+                self.finished = true;
+                if !status.success() {
+                    return Err(anyhow!("daemon exited with {status}"));
+                }
+                return Ok(());
+            }
+            if Instant::now() >= deadline {
+                return Err(anyhow!("daemon did not exit after SIGTERM"));
+            }
+            thread::sleep(Duration::from_millis(20));
+        }
+    }
+}
+
+impl Drop for ChildGuard {
+    fn drop(&mut self) {
+        if !self.finished {
+            let _ = self.child.kill();
+            let _ = self.child.wait();
+        }
+    }
+}
+
+#[test]
+fn daemon_aggregates_processes_and_returns_to_zero() -> Result<()> {
+    let temp_dir = TempDir::new()?;
+    let socket_path = temp_dir.path().join("rate.sock");
+    let state_path = temp_dir.path().join("rate.json");
+    let child = Command::new(codex_utils_cargo_bin::cargo_bin("codex-token-rate-daemon")?)
+        .args([
+            "--socket",
+            &socket_path.to_string_lossy(),
+            "--state-file",
+            &state_path.to_string_lossy(),
+            "--window-ms",
+            "300",
+            "--refresh-ms",
+            "50",
+        ])
+        .stdout(Stdio::null())
+        .stderr(Stdio::null())
+        .spawn()?;
+    let mut child = ChildGuard::new(child);
+    wait_for_path(&socket_path, Duration::from_secs(3))?;
+    assert_eq!(
+        fs::metadata(&socket_path)?.permissions().mode() & 0o777,
+        0o600
+    );
+
+    let sender = UnixDatagram::unbound()?;
+    send_delta(
+        &sender,
+        &socket_path,
+        /*pid*/ 101,
+        "session-a",
+        "101-1",
+        /*estimated_tokens*/ 3,
+    )?;
+    send_delta(
+        &sender,
+        &socket_path,
+        /*pid*/ 202,
+        "session-b",
+        "202-1",
+        /*estimated_tokens*/ 5,
+    )?;
+
+    let largest_individual_rate = 5.0 / 0.3;
+    let active = wait_for_state(&state_path, Duration::from_secs(3), |state| {
+        state.active_sessions == 2
+            && state.active_streams == 2
+            && state.tokens_per_second > largest_individual_rate
+    })?;
+    assert!(active.raw_tokens_per_second > largest_individual_rate);
+
+    send_response_completed(&sender, &socket_path, "session-a", "101-1")?;
+    thread::sleep(Duration::from_millis(350));
+    let held = wait_for_state(&state_path, Duration::from_secs(3), |state| {
+        state.tool_active_streams == 1
+            && state.active_sessions == 1
+            && state.active_streams == 1
+            && state.raw_tokens_per_second == 10.0
+            && state.tokens_per_second == 10.0
+    })?;
+    assert_eq!(held.tool_active_streams, 1);
+
+    send_tool_execution_completed(&sender, &socket_path, "session-a", "101-1")?;
+
+    let idle = wait_for_state(&state_path, Duration::from_secs(3), |state| {
+        state.raw_tokens_per_second == 0.0 && state.tokens_per_second == 0.0
+    })?;
+    assert_eq!(idle.active_sessions, 0);
+    assert_eq!(idle.active_streams, 0);
+
+    child.terminate()?;
+    assert!(!socket_path.exists());
+    Ok(())
+}
+
+fn send_response_completed(
+    sender: &UnixDatagram,
+    socket_path: &std::path::Path,
+    session_id: &str,
+    stream_id: &str,
+) -> Result<()> {
+    let payload = serde_json::to_vec(&json!({
+        "v": 1,
+        "event": "response_completed",
+        "pid": 101,
+        "session_id": session_id,
+        "stream_id": stream_id,
+        "next_phase": "tool_execution",
+    }))?;
+    sender.send_to(&payload, socket_path)?;
+    Ok(())
+}
+
+fn send_tool_execution_completed(
+    sender: &UnixDatagram,
+    socket_path: &std::path::Path,
+    session_id: &str,
+    stream_id: &str,
+) -> Result<()> {
+    let payload = serde_json::to_vec(&json!({
+        "v": 1,
+        "event": "tool_execution_completed",
+        "pid": 101,
+        "session_id": session_id,
+        "stream_id": stream_id,
+    }))?;
+    sender.send_to(&payload, socket_path)?;
+    Ok(())
+}
+
+fn send_delta(
+    sender: &UnixDatagram,
+    socket_path: &std::path::Path,
+    pid: u32,
+    session_id: &str,
+    stream_id: &str,
+    estimated_tokens: u64,
+) -> Result<()> {
+    let payload = serde_json::to_vec(&json!({
+        "v": 1,
+        "event": "delta",
+        "ts_unix_ms": 1,
+        "pid": pid,
+        "session_id": session_id,
+        "turn_id": "turn",
+        "stream_id": stream_id,
+        "model": "test-model",
+        "kind": "visible_output",
+        "estimated_tokens": estimated_tokens,
+        "utf8_bytes": estimated_tokens * 4,
+    }))?;
+    sender.send_to(&payload, socket_path)?;
+    Ok(())
+}
+
+fn wait_for_path(path: &std::path::Path, timeout: Duration) -> Result<()> {
+    let deadline = Instant::now() + timeout;
+    while Instant::now() < deadline {
+        if path.exists() {
+            return Ok(());
+        }
+        thread::sleep(Duration::from_millis(20));
+    }
+    Err(anyhow!("timed out waiting for {}", path.display()))
+}
+
+fn wait_for_state(
+    path: &std::path::Path,
+    timeout: Duration,
+    predicate: impl Fn(&StateFile) -> bool,
+) -> Result<StateFile> {
+    let deadline = Instant::now() + timeout;
+    while Instant::now() < deadline {
+        match fs::read(path) {
+            Ok(bytes) => {
+                let state: StateFile = serde_json::from_slice(&bytes)?;
+                if predicate(&state) {
+                    return Ok(state);
+                }
+            }
+            Err(err) if err.kind() == io::ErrorKind::NotFound => {}
+            Err(err) => return Err(err.into()),
+        }
+        thread::sleep(Duration::from_millis(20));
+    }
+    Err(anyhow!("timed out waiting for state in {}", path.display()))
+}
