+    aggregator.tool_execution_completed(tool_execution_completed("session", "stream"));
+    assert_eq!(
+        aggregator.snapshot(start + Duration::from_secs(30), /*ema_alpha*/ 0.35),
+        AggregateSnapshot {
+            tokens_per_second: 0.0,
+            raw_tokens_per_second: 0.0,
+            active_sessions: 0,
+            active_streams: 0,
+            tool_active_streams: 0,
+        }
