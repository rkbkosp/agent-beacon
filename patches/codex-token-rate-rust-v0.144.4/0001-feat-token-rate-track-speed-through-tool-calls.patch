+#!/usr/bin/env bash
+set -euo pipefail
+
+SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
+REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
+TARGET_DIR="${CARGO_TARGET_DIR:-$REPO_ROOT/codex-rs/target}"
+INSTALL_DIR="${CODEX_PATCH_INSTALL_DIR:-$HOME/.local/bin}"
+
+if [[ "$TARGET_DIR" != /* ]]; then
+  TARGET_DIR="$REPO_ROOT/codex-rs/$TARGET_DIR"
+fi
+
+CODEX_BINARY="$TARGET_DIR/release/codex"
+DAEMON_BINARY="$TARGET_DIR/release/codex-token-rate-daemon"
+
+for binary in "$CODEX_BINARY" "$DAEMON_BINARY"; do
+  if [[ ! -f "$binary" ]]; then
+    printf 'Missing release build: %s\n' "$binary" >&2
+    printf 'Run the two cargo build --release commands first.\n' >&2
+    exit 1
+  fi
+done
+
+install -d "$INSTALL_DIR"
+install -m 755 "$CODEX_BINARY" "$INSTALL_DIR/codex-patched"
+install -m 755 "$DAEMON_BINARY" "$INSTALL_DIR/codex-token-rate-daemon"
+
+CODEX_VERSION="$("$INSTALL_DIR/codex-patched" --version)"
+DAEMON_VERSION="$("$INSTALL_DIR/codex-token-rate-daemon" --version)"
+TEMP_DIR="${TMPDIR:-/tmp}"
+SOCKET_PATH="${TEMP_DIR%/}/codex-token-rate.sock"
+STATE_FILE="${TEMP_DIR%/}/codex-token-rate.json"
+
+printf 'Installed %s\n' "$CODEX_VERSION"
+printf 'Installed %s\n\n' "$DAEMON_VERSION"
+printf 'Start the daemon:\n'
+printf '  %q --socket %q --state-file %q --stdout\n' \
+  "$INSTALL_DIR/codex-token-rate-daemon" "$SOCKET_PATH" "$STATE_FILE"
+printf '\nStart patched Codex in another terminal:\n'
+printf '  export CODEX_TOKEN_RATE_SOCKET=%q\n' "$SOCKET_PATH"
+printf '  %q\n' "$INSTALL_DIR/codex-patched"

