+use serde::Deserialize;
+
+#[derive(Debug, PartialEq)]
+pub(super) struct AggregateSnapshot {
+    pub(super) tokens_per_second: f64,
+    pub(super) raw_tokens_per_second: f64,
+    pub(super) active_sessions: usize,
+    pub(super) active_streams: usize,
+    pub(super) tool_active_streams: usize,
+}
+
+pub(super) struct Aggregator {
+    window: Duration,
+    samples: VecDeque<TokenSample>,
+    held_tool_rates: HashMap<StreamKey, f64>,
+    smoothed_tokens_per_second: f64,
+}
+
+struct TokenSample {
+    received_at: Instant,
+    estimated_tokens: u64,
+    key: StreamKey,
+}
+
+#[derive(Debug, Clone, PartialEq, Eq, Hash)]
+struct StreamKey {
+    session_id: String,
+    stream_id: String,
+}
+
+#[derive(Debug, Deserialize, PartialEq, Eq)]
+pub(super) struct DeltaMessage {
+    #[serde(rename = "pid")]
+    pub(super) _pid: u32,
+    pub(super) session_id: String,
+    pub(super) stream_id: String,
+    pub(super) estimated_tokens: u64,
+}
+
+#[derive(Debug, Clone, Copy, Default, Deserialize, PartialEq, Eq)]
+#[serde(rename_all = "snake_case")]
+pub(super) enum PostResponsePhase {
+    #[default]
+    Idle,
+    ToolExecution,
+}
+
+#[derive(Debug, Deserialize, PartialEq, Eq)]
+pub(super) struct ResponseCompletedMessage {
+    #[serde(rename = "pid")]
+    pub(super) _pid: u32,
+    pub(super) session_id: String,
+    pub(super) stream_id: String,
+    #[serde(default)]
+    pub(super) next_phase: PostResponsePhase,
+}
+
+#[derive(Debug, Deserialize, PartialEq, Eq)]
+pub(super) struct ToolExecutionCompletedMessage {
+    #[serde(rename = "pid")]
+    pub(super) _pid: u32,
+    pub(super) session_id: String,
+    pub(super) stream_id: String,
+}
+
+impl Aggregator {
+    pub(super) fn new(window: Duration) -> Self {
+        Self {
+            window,
+            samples: VecDeque::new(),
+            held_tool_rates: HashMap::new(),
+            smoothed_tokens_per_second: 0.0,
+        }
+    }
+
+    pub(super) fn record(&mut self, received_at: Instant, delta: DeltaMessage) {
+        self.held_tool_rates
+            .retain(|key, _| key.session_id != delta.session_id);
+        self.samples.push_back(TokenSample {
+            received_at,
+            estimated_tokens: delta.estimated_tokens,
+            key: StreamKey {
+                session_id: delta.session_id,
+                stream_id: delta.stream_id,
+            },
+        });
+    }
+
+    pub(super) fn response_completed(
+        &mut self,
+        received_at: Instant,
+        completed: ResponseCompletedMessage,
+    ) {
+        let key = StreamKey {
+            session_id: completed.session_id,
+            stream_id: completed.stream_id,
+        };
+        match completed.next_phase {
+            PostResponsePhase::Idle => {
+                self.held_tool_rates.remove(&key);
+            }
+            PostResponsePhase::ToolExecution => {
+                self.expire_samples(received_at);
+                let estimated_tokens = self
+                    .samples
+                    .iter()
+                    .filter(|sample| sample.key == key)
+                    .fold(0_u64, |total, sample| {
+                        total.saturating_add(sample.estimated_tokens)
+                    });
+                self.samples.retain(|sample| sample.key != key);
+                self.held_tool_rates
+                    .insert(key, estimated_tokens as f64 / self.window.as_secs_f64());
+            }
+        }
+    }
+
+    pub(super) fn tool_execution_completed(&mut self, completed: ToolExecutionCompletedMessage) {
+        self.held_tool_rates.remove(&StreamKey {
+            session_id: completed.session_id,
+            stream_id: completed.stream_id,
+        });
+    }
+
+    pub(super) fn snapshot(&mut self, now: Instant, ema_alpha: f64) -> AggregateSnapshot {
+        self.expire_samples(now);
+
+        let live_tokens = self.samples.iter().fold(0_u64, |total, sample| {
+            total.saturating_add(sample.estimated_tokens)
+        });
+        let live_tokens_per_second = live_tokens as f64 / self.window.as_secs_f64();
+        let held_tokens_per_second = self.held_tool_rates.values().sum::<f64>();
+        let raw_tokens_per_second = live_tokens_per_second + held_tokens_per_second;
+        self.smoothed_tokens_per_second = if !self.samples.is_empty() {
+            ema_alpha * raw_tokens_per_second + (1.0 - ema_alpha) * self.smoothed_tokens_per_second
+        } else if !self.held_tool_rates.is_empty() {
+            raw_tokens_per_second
+        } else {
+            0.0
+        };
+        let active_sessions = self
+            .samples
+            .iter()
+            .map(|sample| sample.key.session_id.as_str())
+            .chain(
+                self.held_tool_rates
+                    .keys()
+                    .map(|key| key.session_id.as_str()),
+            )
+            .collect::<HashSet<_>>()
+            .len();
+        let active_streams = self
+            .samples
+            .iter()
+            .map(|sample| {
+                (
+                    sample.key.session_id.as_str(),
+                    sample.key.stream_id.as_str(),
+                )
+            })
+            .chain(
+                self.held_tool_rates
+                    .keys()
+                    .map(|key| (key.session_id.as_str(), key.stream_id.as_str())),
+            )
+            .collect::<HashSet<_>>()
+            .len();
+
+        AggregateSnapshot {
+            tokens_per_second: self.smoothed_tokens_per_second,
+            raw_tokens_per_second,
+            active_sessions,
+            active_streams,
+            tool_active_streams: self.held_tool_rates.len(),
+        }
+    }
+
+    fn expire_samples(&mut self, now: Instant) {
+        let cutoff = now.checked_sub(self.window).unwrap_or(now);
+        while self
+            .samples
+            .front()
+            .is_some_and(|sample| sample.received_at < cutoff)
+        {
+            self.samples.pop_front();
+        }
+    }
+}
+
