+use std::ffi::OsString;
+use std::fs;
+use std::fs::OpenOptions;
+use std::io;
+use std::io::Write;
+use std::os::unix::fs::FileTypeExt;
+use std::os::unix::fs::MetadataExt;
+use std::os::unix::fs::OpenOptionsExt;
+use std::os::unix::fs::PermissionsExt;
+use std::os::unix::net::UnixDatagram as StdUnixDatagram;
+use std::path::Path;
+use std::path::PathBuf;
+use std::sync::atomic::AtomicU64;
+use std::sync::atomic::Ordering;
+use std::time::Duration;
+use std::time::Instant;
+use std::time::SystemTime;
+use std::time::UNIX_EPOCH;
+
+use anyhow::Context;
+use anyhow::Result;
+use anyhow::bail;
+use clap::Parser;
+use serde::Deserialize;
+use serde::Serialize;
+use tokio::net::UnixDatagram;
+use tokio::time::MissedTickBehavior;
+
+use crate::aggregation::Aggregator;
+use crate::aggregation::DeltaMessage;
+use crate::aggregation::ResponseCompletedMessage;
+use crate::aggregation::ToolExecutionCompletedMessage;
+
+const PROTOCOL_VERSION: u64 = 1;
+const METRIC_NAME: &str = "completion_output_tokens_per_second";
+const MAX_DATAGRAM_BYTES: usize = 16 * 1024;
+const MAX_ID_BYTES: usize = 512;
+const WARNING_INTERVAL: Duration = Duration::from_secs(5);
+
+static NEXT_STATE_TEMP_FILE: AtomicU64 = AtomicU64::new(1);
+
+#[derive(Debug, Parser)]
+#[command(name = "codex-token-rate-daemon", version)]
+pub(crate) struct Args {
+    #[arg(long, value_name = "PATH")]
+    socket: Option<PathBuf>,
+
+    #[arg(long, value_name = "PATH")]
+    state_file: Option<PathBuf>,
+
+    #[arg(long, default_value_t = 2000)]
+    window_ms: u64,
+
+    #[arg(long, default_value_t = 200)]
+    refresh_ms: u64,
+
+    #[arg(long, default_value_t = 0.35, value_parser = parse_ema_alpha)]
+    ema_alpha: f64,
+
+    #[arg(long)]
+    stdout: bool,
+}
+
+struct Config {
+    socket_path: PathBuf,
+    state_file: PathBuf,
+    window: Duration,
+    refresh: Duration,
+    ema_alpha: f64,
+    stdout: bool,
+}
+
+#[derive(Debug, Clone, PartialEq, Serialize)]
+struct StateFile {
+    version: u8,
+    metric: &'static str,
+    estimated: bool,
+    tokens_per_second: f64,
+    raw_tokens_per_second: f64,
+    active_sessions: usize,
+    active_streams: usize,
+    tool_active_streams: usize,
+    window_ms: u64,
+    updated_at_unix_ms: u64,
+}
+
+#[derive(Deserialize)]
+struct MessageEnvelope {
+    v: u64,
+    event: String,
+}
+
+#[derive(Debug, PartialEq, Eq)]
+enum ParsedDatagram {
+    Delta(DeltaMessage),
+    ResponseCompleted(ResponseCompletedMessage),
+    ToolExecutionCompleted(ToolExecutionCompletedMessage),
+    Ignored(IgnoreReason),
+}
+
+#[derive(Debug, PartialEq, Eq)]
+enum IgnoreReason {
+    Malformed,
+    UnsupportedVersion,
+    UnknownEvent,
+}
+
+struct WarningLimiter {
+    next_allowed_at: Option<Instant>,
+}
+
+struct SocketPathGuard {
+    path: PathBuf,
+    device: u64,
+    inode: u64,
+}
+
+struct TempPathGuard {
+    path: Option<PathBuf>,
+}
+
+pub(crate) async fn run(args: Args) -> Result<()> {
+    let config = Config::try_from(args)?;
+    prepare_socket_path(&config.socket_path)?;
+    let socket = UnixDatagram::bind(&config.socket_path)
+        .with_context(|| format!("socket bind failed: {}", config.socket_path.display()))?;
+    let socket_guard = SocketPathGuard::new(config.socket_path.clone())?;
+    fs::set_permissions(&config.socket_path, fs::Permissions::from_mode(0o600))?;
+
+    let mut aggregator = Aggregator::new(config.window);
+    let mut refresh = tokio::time::interval(config.refresh);
+    refresh.set_missed_tick_behavior(MissedTickBehavior::Skip);
+    let mut protocol_warning = WarningLimiter::new();
+    let mut state_warning = WarningLimiter::new();
+    let mut buffer = [0_u8; MAX_DATAGRAM_BYTES];
+    let shutdown = shutdown_signal();
+    tokio::pin!(shutdown);
+
+    loop {
+        tokio::select! {
+            _ = &mut shutdown => break,
+            result = socket.recv(&mut buffer) => {
+                match result {
+                    Ok(size) => handle_datagram(
+                        &buffer[..size],
+                        Instant::now(),
+                        &mut aggregator,
+                        &mut protocol_warning,
+                    ),
+                    Err(err) if err.kind() == io::ErrorKind::Interrupted => {}
+                    Err(err) => return Err(err).context("socket receive failed"),
+                }
+            }
+            _ = refresh.tick() => {
+                let now = Instant::now();
+                let snapshot = aggregator.snapshot(now, config.ema_alpha);
+                let state = StateFile {
+                    version: 1,
+                    metric: METRIC_NAME,
+                    estimated: true,
+                    tokens_per_second: round_to_tenth(snapshot.tokens_per_second),
+                    raw_tokens_per_second: round_to_tenth(snapshot.raw_tokens_per_second),
+                    active_sessions: snapshot.active_sessions,
+                    active_streams: snapshot.active_streams,
+                    tool_active_streams: snapshot.tool_active_streams,
+                    window_ms: duration_millis(config.window),
+                    updated_at_unix_ms: unix_timestamp_ms(),
+                };
+                if let Err(err) = write_state_atomically(&config.state_file, &state) {
+                    state_warning.warn(now, &format!("state file write failed: {err}"));
+                }
+                if config.stdout {
+                    println!(
+                        "≈ {:.1} tok/s | sessions {} | streams {} | tools {}",
+                        state.tokens_per_second,
+                        state.active_sessions,
+                        state.active_streams,
+                        state.tool_active_streams,
+                    );
+                }
+            }
+        }
+    }
+
+    drop(socket_guard);
+    Ok(())
+}
+
+impl TryFrom<Args> for Config {
+    type Error = anyhow::Error;
+
+    fn try_from(args: Args) -> Result<Self> {
+        if args.window_ms == 0 {
+            bail!("--window-ms must be greater than zero");
+        }
+        if args.refresh_ms == 0 {
+            bail!("--refresh-ms must be greater than zero");
+        }
+        if !valid_ema_alpha(args.ema_alpha) {
+            bail!("--ema-alpha must be greater than zero and at most one");
+        }
+        let socket_path = args
+            .socket
+            .unwrap_or_else(|| std::env::temp_dir().join("codex-token-rate.sock"));
+        if !socket_path.is_absolute() {
+            bail!("socket path must be absolute: {}", socket_path.display());
+        }
+        Ok(Self {
+            socket_path,
+            state_file: args
+                .state_file
+                .unwrap_or_else(|| std::env::temp_dir().join("codex-token-rate.json")),
+            window: Duration::from_millis(args.window_ms),
+            refresh: Duration::from_millis(args.refresh_ms),
+            ema_alpha: args.ema_alpha,
+            stdout: args.stdout,
+        })
+    }
+}
+
+impl WarningLimiter {
+    fn new() -> Self {
+        Self {
+            next_allowed_at: None,
+        }
+    }
+
+    fn warn(&mut self, now: Instant, message: &str) {
+        if self.next_allowed_at.is_none_or(|next| now >= next) {
+            eprintln!("{message}");
+            self.next_allowed_at = Some(now + WARNING_INTERVAL);
+        }
+    }
+}
+
+impl SocketPathGuard {
+    fn new(path: PathBuf) -> io::Result<Self> {
+        let metadata = fs::symlink_metadata(&path)?;
+        Ok(Self {
+            path,
+            device: metadata.dev(),
+            inode: metadata.ino(),
+        })
+    }
+}
+
+impl Drop for SocketPathGuard {
+    fn drop(&mut self) {
+        if let Ok(metadata) = fs::symlink_metadata(&self.path)
+            && metadata.file_type().is_socket()
+            && metadata.dev() == self.device
+            && metadata.ino() == self.inode
+        {
+            let _ = fs::remove_file(&self.path);
+        }
+    }
+}
+
+impl TempPathGuard {
+    fn new(path: PathBuf) -> Self {
+        Self { path: Some(path) }
+    }
+
+    fn persist(mut self) {
+        self.path = None;
+    }
+}
+
+impl Drop for TempPathGuard {
+    fn drop(&mut self) {
+        if let Some(path) = self.path.as_ref() {
+            let _ = fs::remove_file(path);
+        }
+    }
+}
+
+fn handle_datagram(
+    datagram: &[u8],
+    received_at: Instant,
+    aggregator: &mut Aggregator,
+    warning: &mut WarningLimiter,
+) {
+    match parse_datagram(datagram) {
+        ParsedDatagram::Delta(delta) => aggregator.record(received_at, delta),
+        ParsedDatagram::ResponseCompleted(completed) => {
+            aggregator.response_completed(received_at, completed);
+        }
+        ParsedDatagram::ToolExecutionCompleted(completed) => {
+            aggregator.tool_execution_completed(completed);
+        }
+        ParsedDatagram::Ignored(IgnoreReason::UnknownEvent) => {}
+        ParsedDatagram::Ignored(IgnoreReason::Malformed) => {
+            warning.warn(received_at, "malformed datagram ignored");
+        }
+        ParsedDatagram::Ignored(IgnoreReason::UnsupportedVersion) => {
+            warning.warn(received_at, "unsupported protocol version");
+        }
+    }
+}
+
+fn parse_datagram(datagram: &[u8]) -> ParsedDatagram {
+    let Ok(envelope) = serde_json::from_slice::<MessageEnvelope>(datagram) else {
+        return ParsedDatagram::Ignored(IgnoreReason::Malformed);
+    };
+    if envelope.v != PROTOCOL_VERSION {
+        return ParsedDatagram::Ignored(IgnoreReason::UnsupportedVersion);
+    }
+    match envelope.event.as_str() {
+        "delta" => {
+            let Ok(delta) = serde_json::from_slice::<DeltaMessage>(datagram) else {
+                return ParsedDatagram::Ignored(IgnoreReason::Malformed);
+            };
+            if delta.estimated_tokens == 0 || !valid_stream_ids(&delta.session_id, &delta.stream_id)
+            {
+                ParsedDatagram::Ignored(IgnoreReason::Malformed)
+            } else {
+                ParsedDatagram::Delta(delta)
+            }
+        }
+        "response_completed" => {
+            let Ok(completed) = serde_json::from_slice::<ResponseCompletedMessage>(datagram) else {
+                return ParsedDatagram::Ignored(IgnoreReason::Malformed);
+            };
+            if valid_stream_ids(&completed.session_id, &completed.stream_id) {
+                ParsedDatagram::ResponseCompleted(completed)
+            } else {
+                ParsedDatagram::Ignored(IgnoreReason::Malformed)
+            }
+        }
+        "tool_execution_completed" => {
+            let Ok(completed) = serde_json::from_slice::<ToolExecutionCompletedMessage>(datagram)
+            else {
+                return ParsedDatagram::Ignored(IgnoreReason::Malformed);
+            };
+            if valid_stream_ids(&completed.session_id, &completed.stream_id) {
+                ParsedDatagram::ToolExecutionCompleted(completed)
+            } else {
+                ParsedDatagram::Ignored(IgnoreReason::Malformed)
+            }
+        }
+        _ => ParsedDatagram::Ignored(IgnoreReason::UnknownEvent),
+    }
+}
+
+fn valid_stream_ids(session_id: &str, stream_id: &str) -> bool {
+    !session_id.is_empty()
+        && session_id.len() <= MAX_ID_BYTES
+        && !stream_id.is_empty()
+        && stream_id.len() <= MAX_ID_BYTES
+}
+
+fn prepare_socket_path(path: &Path) -> Result<()> {
+    if !path.is_absolute() {
+        bail!("socket path must be absolute: {}", path.display());
+    }
+    let metadata = match fs::symlink_metadata(path) {
+        Ok(metadata) => metadata,
+        Err(err) if err.kind() == io::ErrorKind::NotFound => return Ok(()),
+        Err(err) => return Err(err.into()),
+    };
+    if !metadata.file_type().is_socket() {
+        bail!(
+            "socket path exists and is not a Unix socket: {}",
+            path.display()
+        );
+    }
+    // SAFETY: geteuid has no preconditions and does not retain pointers.
+    let current_uid = unsafe { libc::geteuid() };
+    if metadata.uid() != current_uid {
+        bail!(
+            "refusing to remove a socket owned by another user: {}",
+            path.display()
+        );
+    }
+
+    let probe = StdUnixDatagram::unbound()?;
+    match probe.connect(path) {
+        Ok(()) => bail!("socket is already in use: {}", path.display()),
+        Err(err) if is_stale_socket_error(&err) => {
+            fs::remove_file(path)?;
+            Ok(())
+        }
+        Err(err) => {
+            Err(err).with_context(|| format!("failed to inspect socket: {}", path.display()))
+        }
+    }
+}
+
+fn is_stale_socket_error(error: &io::Error) -> bool {
+    matches!(
+        error.kind(),
+        io::ErrorKind::ConnectionRefused | io::ErrorKind::NotFound
+    )
+}
+
+fn write_state_atomically(path: &Path, state: &StateFile) -> io::Result<()> {
+    let temp_path = state_temp_path(path)?;
+    let temp_guard = TempPathGuard::new(temp_path.clone());
+    let mut file = OpenOptions::new()
+        .write(true)
+        .create_new(true)
+        .mode(0o600)
+        .open(&temp_path)?;
+    fs::set_permissions(&temp_path, fs::Permissions::from_mode(0o600))?;
+    serde_json::to_writer(&mut file, state).map_err(io::Error::other)?;
+    file.write_all(b"\n")?;
+    file.flush()?;
+    drop(file);
+    fs::rename(&temp_path, path)?;
+    temp_guard.persist();
+    Ok(())
+}
+
+fn state_temp_path(path: &Path) -> io::Result<PathBuf> {
+    let file_name = path.file_name().ok_or_else(|| {
+        io::Error::new(io::ErrorKind::InvalidInput, "state file has no file name")
+    })?;
+    let parent = path.parent().unwrap_or_else(|| Path::new("."));
+    let sequence = NEXT_STATE_TEMP_FILE.fetch_add(1, Ordering::Relaxed);
+    let mut temp_name = OsString::from(".");
+    temp_name.push(file_name);
+    temp_name.push(format!(".tmp-{}-{sequence}", std::process::id()));
+    Ok(parent.join(temp_name))
+}
+
+fn parse_ema_alpha(value: &str) -> std::result::Result<f64, String> {
+    let alpha = value
+        .parse::<f64>()
+        .map_err(|err| format!("invalid EMA alpha: {err}"))?;
+    if valid_ema_alpha(alpha) {
+        Ok(alpha)
+    } else {
+        Err("EMA alpha must be greater than zero and at most one".to_string())
+    }
+}
+
+fn valid_ema_alpha(alpha: f64) -> bool {
+    alpha.is_finite() && alpha != 0.0 && (0.0..=1.0).contains(&alpha)
+}
+
+fn round_to_tenth(value: f64) -> f64 {
+    (value * 10.0).round() / 10.0
+}
+
+fn duration_millis(duration: Duration) -> u64 {
+    u64::try_from(duration.as_millis()).unwrap_or(u64::MAX)
+}
+
+fn unix_timestamp_ms() -> u64 {
+    let millis = SystemTime::now()
+        .duration_since(UNIX_EPOCH)
+        .unwrap_or_default()
+        .as_millis();
+    u64::try_from(millis).unwrap_or(u64::MAX)
+}
+
+async fn shutdown_signal() {
+    let ctrl_c = tokio::signal::ctrl_c();
+    match tokio::signal::unix::signal(tokio::signal::unix::SignalKind::terminate()) {
+        Ok(mut terminate) => {
+            tokio::select! {
+                _ = ctrl_c => {}
+                _ = terminate.recv() => {}
+            }
+        }
+        Err(_) => {
+            let _ = ctrl_c.await;
+        }
+    }
+}
+
